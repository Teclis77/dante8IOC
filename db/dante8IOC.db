#
#
#	Status Routines
#
record(ai, "$(DETECT)_$(card)_$(axis):type") {
	field(DESC, "Type of detector")
	field(SCAN, "Passive")
	field(VAL, "2")
	field(PINI, "YES")
}
record(bo, "$(DETECT):reqsnl") {
	field(DESC, "Request if SNL is online")
	field(VAL, "1")
	field(PINI, "YES")
	field(FLNK, "$(DETECT):evalsnl")
}
record(stringin, "$(DETECT):evalsnl") {
	field(DESC, "Evaluate if SNL online")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(INP, "$(ASYNPORT):dante:AsynIO.CNCT CP MS")
	field(FLNK, "$(DETECT):snl_status")
	field(PINI, "YES")
}
record(scalcout, "$(DETECT):snl_status") {
	field(DESC, "Eval if SNL online")
	field(SCAN, "Passive")
	field(INAA, "$(DETECT):evalsnl CP")
	field(CALC, "AA=='Connect'?1:0")
}
record(bo, "$(DETECT):reqname") {
	field(DESC, "Request Model Name")
	field(VAL, "1")
	field(PINI, "YES")
	field(FLNK, "$(DETECT):model_name")
}
record(stringin, "$(DETECT):model_name") {
	field(DESC, "Model Device")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(INP, "$(ASYNPORT):dante:PortName_RBV CP MS")
	field(FLNK, "$(DETECT):reqmodel")
	field(PINI, "YES")
}
record(scalcout, "$(DETECT):reqmodel") {
	field(DESC, "Query if IOC online")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(INAA, "$(DETECT):model_name CP")
	field(CALC, "LEN(AA)>0?1:0")
	field(FLNK, "$(DETECT):model_calc")
}
record(scalcout, "$(DETECT):model_calc") {
	field(DESC, "Eval Connection Status")
        field(INPA, "$(DETECT):reqmodel CP") 
	field(INPB, "$(DETECT):snl_status CP") 
	field(CALC, "(A&&B)?'$(DETECT) Online':'$(DETECT) Offline'")
        field(OUT, "$(DETECT):model.VAL PP")
	field(FLNK, "$(DETECT):model.PROC")
#	field(OOPT, "Every Time")
}
record(stringin, "$(DETECT):model") {
	field(DESC, "Connection Status")
	field(VAL, "$(DETECT) Offline")
	field(PINI, "YES")
}
record(stringin, "$(DETECT)_$(card)_$(axis):busy") {
	field(DESC, "Busy $(card)_$(axis) - (0=busy, 1=ready)")
	field(SCAN, "Passive")
	field(VAL, "1")
	field(PINI, "YES")
}
#
#       Path Save
#
record(stringout, $(DETECT):scan:filepath) {
	field(DESC, "Output file path")
	field(VAL, "temp/data")
	field(PINI, "YES")
}
#
#	Board
#
record(bo, "$(DETECT)_$(card)_$(axis):enable") {
	field(DESC, "Enable Board $(card) $(axis)")
        field(SCAN, "Passive")
        field(DTYP, "Soft Channel")
        field(OUT, "$(ASYNPORT):dante$(axis):EnableBoard PP")
	field(VAL, "1")
        field(PINI, "YES")
	field(FLNK, "$(DETECT)_$(card)_$(axis):enable_status")
}
record(stringin, "$(DETECT)_$(card)_$(axis):enable_status") {
	field(DESC, "Status Board $(card) $(axis)")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
#	field(INP, "$(ASYNPORT):dante$(axis):EnableBoard CP MS")
	field(INP, "$(ASYNPORT):dante$(axis):EnableBoard_RBV CP MS")
}
#
#	Reset Routines
#
record(bo, "$(DETECT)_$(card)_$(axis):reqreset") {
	field(DESC, "Req. Reset $(card) $(axis)")
	field(FLNK, "$(DETECT)_$(card)_$(axis):reset")
	field(PINI, "NO")
}
record(bo, "$(DETECT)_$(card)_$(axis):reset") {
	field(DESC, "Reset $(card) $(axis)")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(OUT, "$(ASYNPORT):mca$(axis)Erase PP")
	field(ZNAM, "0")
	field(ONAM, "1")
	field(VAL, "0")
}
#
#	Time
#
record(bo, "$(DETECT)_$(card)_$(axis):reqgettime") {
	field(DESC, "Req. Time")
	field(FLNK, "$(DETECT)_$(card)_$(axis):gettime")
	field(PINI, "YES")
}
record(ai, "$(DETECT)_$(card)_$(axis):gettime") {
	field(DESC, "Get Time")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(INP, "$(ASYNPORT):dante:PresetReal CP MS")
}
record(ao, "$(DETECT)_$(card)_$(axis):settime") {
	field(DESC, "Set Time")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(OUT, "$(ASYNPORT):dante:PresetReal PP")
	field(PINI, "NO")
}
#
#	Is ready?
#
record(bo, "$(DETECT)_$(card)_$(axis):reqready") {
	field(DESC, "Req. ready $(card) $(axis)")
	field(FLNK, "$(DETECT)_$(card)_$(axis):ready_status")
}
record(stringin, "$(DETECT)_$(card)_$(axis):term_ready") {
	field(DESC, "Terminator for Detector Status")
	field(VAL, "$(ready)")
	field(PINI, "YES")
}
record(stringin, "$(DETECT)_$(card)_$(axis):ready_status") {
	field(DESC, "Actual Time")
        field(DTYP, "Soft Channel")
	field(INP, "$(ASYNPORT):dante:AcquireBusy CP MS")
	field(FLNK, "$(DETECT)_$(card)_$(axis):ready")
}
record(scalcout, "$(DETECT)_$(card)_$(axis):ready") {
	field(DESC, "Is ready?")
	field(INAA, "$(DETECT)_$(card)_$(axis):ready_status")
	field(INBB, "$(DETECT)_$(card)_$(axis):term_ready")
	field(CALC, "AA=BB?1:0")
}
#
#	Acquisition Routines
#
record(bo, "$(DETECT)_$(card)_$(axis):reqstart") {
	field(DESC, "Req. Acq. $(card) $(axis)")
	field(FLNK, "$(DETECT)_$(card)_$(axis):start")
	field(PINI, "NO")
}
record(bo, "$(DETECT)_$(card)_$(axis):start") {
	field(DESC, "Start Acq. $(card) $(axis)")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(OUT, "$(ASYNPORT):mca$(axis)EraseStart PP")
	field(ZNAM, "0")
	field(ONAM, "1")
	field(VAL, "0")
}
record(bo, "$(DETECT)_$(card)_$(axis):stop") {
        field(DESC, "Stop Acq. $(card) $(axis)")
        field(SCAN, "Passive")
        field(DTYP, "Soft Channel")
        field(OUT, "$(ASYNPORT):mca$(axis)Stop PP")
        field(ZNAM, "0")
        field(ONAM, "1")
        field(VAL, "0")
}
#
#	Data Routines
#
record(bo, "$(DETECT)_$(card)_$(axis):reqdata") {
	field(DESC, "Request data $(card) $(axis)")
	field(FLNK, "$(DETECT)_$(card)_$(axis):data")
	field(PINI, "NO")
}
record(mbbi, "$(DETECT)_$(card)_$(axis):num_cha"){
        field(DESC, "Num Channel $(card) $(axis)")
        field(SCAN, "Passive")
        field(DTYP, "Soft Channel")
        field(INP, "$(ASYNPORT):dante:NumMCAChannels CP MS")
	field(ZRST, "1024")
	field(ONST, "2048")
	field(TWST, "4096")
	field(ZRVL, "0")
	field(ONVL, "1")
	field(TWVL, "2")
}
record(waveform, "$(DETECT)_$(card)_$(axis):data") {
	field(DESC, "Data $(card) $(axis)")
	field(NELM, "4096")
	field(SCAN, "Passive")
	field(DTYP, "Soft Channel")
	field(INP, "$(ASYNPORT):mca$(axis) CP MS")
}
record(stringout, "$(DETECT)_$(card)_$(axis):dataout") {
        field(DESC, "Name of file to store")
        field(PINI, "NO")
	field(VAL, "test.dat")
        field(FLNK, "$(DETECT)_$(card)_$(axis):set_status")
}
#record(calcout, "$(DETECT)_$(card)_$(axis):set_status") {
record(bo, "$(DETECT)_$(card)_$(axis):set_status") {
	field(DESC, "Set status to 1")
	field(FLNK, "$(DETECT)_$(card)_$(axis):set_status_calc")
	field(PINI, "NO")
}
record(calcout, "$(DETECT)_$(card)_$(axis):set_status_calc") {
	field(CALC, "1")
	field(OUT,  "$(DETECT)_$(card)_$(axis):status PP")
	field(OOPT, "Every Time")
	field(DOPT, "Use CALC")
}
record(ai, "$(DETECT)_$(card)_$(axis):status") {
	field(DESC, "status save")
	field(SCAN, "Passive")
	field(PINI, "NO")
}
